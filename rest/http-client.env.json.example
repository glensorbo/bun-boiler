{
  "$schema": "https://getkulala.net/http-client.env.schema.json",
  "dev": {
    "BASE_URL": "http://localhost:3000",
    "JWT_TOKEN": "your-dev-jwt-token-here",
    "SIGNUP_TOKEN": "your-dev-signup-token-here"
  },
  "test": {
    "BASE_URL": "http://localhost:3000",
    "JWT_TOKEN": "your-test-jwt-token-here",
    "SIGNUP_TOKEN": "your-test-signup-token-here"
  },
  "prod": {
    "BASE_URL": "https://your-app.com",
    "JWT_TOKEN": "your-prod-jwt-token-here",
    "SIGNUP_TOKEN": "your-prod-signup-token-here"
  }
}
