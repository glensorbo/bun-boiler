# Server
NODE_ENV=development

# Database (PostgreSQL connection string)
# Used by the app at runtime — matches the POSTGRES_* vars below
DATABASE_URL=postgres://bun_boiler_user:bun_boiler_pass@localhost:5432/bun_boiler

# PostgreSQL (used by Docker / docker-compose)
POSTGRES_DB=bun_boiler
POSTGRES_USER=bun_boiler_user
POSTGRES_PASSWORD=bun_boiler_pass

# Auth (used to sign and verify JWTs)
JWT_SECRET=your-secret-key-here
