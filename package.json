{
  "name": "bun-react-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun db:migrate && bun db:seed & bun --hot backend/server.ts",
    "start": "NODE_ENV=production bun backend/server.ts",
    "build": "bun run build.ts",
    "test": "bun test ./backend ./frontend",
    "test:watch": "bun test --watch ./backend ./frontend",
    "lint": "bunx oxlint --type-aware --type-check",
    "lint:fix": "oxlint --fix",
    "lint:compiler": "bunx eslint --config eslint.config.js 'frontend/**/*.{ts,tsx,js,jsx}'",
    "format:check": "bunx oxfmt --check",
    "format": "bunx oxfmt",
    "cc": "bun format:check && bun knip && bun lint:compiler && bun lint && bun test ./backend ./frontend",
    "knip": "knip-bun",
    "prepare": "husky",
    "db:generate": "bunx --bun drizzle-kit generate",
    "db:migrate": "bunx --bun drizzle-kit migrate",
    "db:seed": "bun backend/db/seed.ts",
    "db:push": "bunx --bun drizzle-kit check && bunx --bun drizzle-kit push",
    "db:studio": "bunx --bun drizzle-kit studio",
    "e2e": "bunx playwright test --project=api",
    "e2e:browser": "bunx playwright test --project=browser",
    "e2e:all": "bunx playwright test",
    "e2e:ui": "bunx playwright test --ui --project=api --project=browser",
    "e2e:debug": "bunx playwright test --debug",
    "e2e:docker": "./scripts/e2e-ci.sh",
    "tag": "bun scripts/tag.ts",
    "release": "bun scripts/release.ts"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "@mui/x-charts": "^9.0.2",
    "@mui/x-data-grid": "^9.0.2",
    "@openpanel/web": "^1.3.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.215.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.215.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.215.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/instrumentation-fetch": "^0.215.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-logs": "^0.215.0",
    "@opentelemetry/sdk-metrics": "^2.7.0",
    "@opentelemetry/sdk-trace-base": "^2.7.0",
    "@opentelemetry/sdk-trace-node": "^2.7.0",
    "@opentelemetry/sdk-trace-web": "^2.7.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@reduxjs/toolkit": "^2.11.2",
    "dayjs": "^1.11.20",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "husky": "^9.1.7",
    "jose": "^6.2.2",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "postgres": "^3.4.9",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-error-boundary": "^6.1.1",
    "react-redux": "^9.2.0",
    "react-router": "^7.14.1",
    "react-toastify": "^11.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@happy-dom/global-registrator": "^20.9.0",
    "@playwright/test": "^1.59.1",
    "@types/babel__core": "^7.20.5",
    "@types/bun": "1.3.12",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "knip": "^6.6.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "oxlint-tsgolint": "^0.21.1",
    "typescript-eslint": "^8.59.0"
  }
}
