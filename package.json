{
  "name": "bun-react-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot backend/server.ts",
    "start": "NODE_ENV=production bun backend/server.ts",
    "build": "bun run build.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "lint": "bunx oxlint --type-aware --type-check",
    "lint:fix": "oxlint --fix",
    "lint:compiler": "bunx eslint --config eslint.config.js 'frontend/**/*.{ts,tsx,js,jsx}'",
    "format:check": "bunx oxfmt --check",
    "format": "bunx oxfmt",
    "cc": "bun test && bun lint && bun lint:compiler && bun format:check",
    "prepare": "husky",
    "db:generate": "bunx --bun drizzle-kit generate",
    "db:migrate": "bunx --bun drizzle-kit migrate",
    "db:seed": "bun backend/db/seed.ts",
    "db:push": "bunx --bun drizzle-kit check && bunx --bun drizzle-kit push",
    "db:studio": "bunx --bun drizzle-kit studio"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.2.2",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@reduxjs/toolkit": "^2.11.2",
    "dayjs": "^1.11.20",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "husky": "^9.1.7",
    "jose": "^6.2.2",
    "pg": "^8.20.0",
    "postgres": "^3.4.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.0",
    "react-redux": "^9.2.0",
    "react-router": "^7.13.2",
    "react-toastify": "^11.0.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@happy-dom/global-registrator": "^20.8.9",
    "@types/babel__core": "^7.20.5",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "^0.18.0",
    "typescript-eslint": "^8.57.2"
  }
}
