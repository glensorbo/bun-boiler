# ── E2E app image ─────────────────────────────────────────────────────────────
# Schema and seed data are applied by the db service's SQL init scripts.
# This image just builds the app and starts the production server.
FROM oven/bun:1

WORKDIR /app

COPY package.json bun.lock ./
RUN bun install --frozen-lockfile

COPY . .

RUN bun run build

EXPOSE 3000

CMD ["bun", "run", "start"]
