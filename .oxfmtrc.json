{
  "trailingComma": "all",
  "tabWidth": 2,
  "semi": true,
  "singleQuote": true,
  "printWidth": 80,
  "sortImports": {
    "newlinesBetween": false,
    "internalPattern": ["@frontend/", "@backend/", "./", "../"],
    "groups": [
      ["value-external", "value-builtin"],
      ["value-internal", "value-parent", "value-sibling", "value-index"],
      "type",
      ["style", "side_effect_style"],
      "side_effect"
    ]
  },
  "ignorePatterns": ["dist/", "coverage/", "backend/db/migrations"],
  "sortPackageJson": true
}
